    "# @title 🛠️ Step 1: Install & Imports\n",
    "!pip install -q firebase-admin transformers accelerate bitsandbytes torch tqdm\n",
    "\n",
    "import os, json, re, torch, time, binascii\n",
    "from tqdm.auto import tqdm\n",
    "import firebase_admin\n",
    "from firebase_admin import credentials, firestore\n",
    "from google.colab import files\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig\n",
    "\n",
    "print(\"✅ Core Libraries Ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "firebase" },
   "outputs": [],
   "source": [
    "# @title 🔑 Step 2: Firestore Connection (Memory Core)\n",
    "DATABASE_ID = 'ai-studio-09d97652-b1c3-4b1a-b63e-31d8a38be4c2'\n",
    "\n",
    "if not firebase_admin._apps:\n",
    "    print(\"Please upload your serviceAccountKey.json file from Firebase Console Settings > Service Accounts:\")\n",
    "    uploaded = files.upload()\n",
    "    if not uploaded:\n",
    "        raise ValueError(\"❌ No Service Account Key uploaded. Stop.\")\n",
    "    filename = list(uploaded.keys())[0]\n",
    "    cred = credentials.Certificate(filename)\n",
    "    firebase_admin.initialize_app(cred)\n",
    "\n",
    "db = firestore.client(database_id=DATABASE_ID)\n",
    "print(f\"✅ Successfully Linked to Firestore: {DATABASE_ID}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "logic_core" },
   "outputs": [],
   "source": [
    "# @title 🧬 Step 3: Logic Mapping & State System\n",
    "CHECKPOINT_FILE = \"ingestion_state_v3.json\"\n",
    "\n",
    "def clean_id(text):\n",
    "    \"\"\"Standard Normalizer - Essential for linking Concept A to Concept B.\"\"\"\n",
    "    if not text: return \"\"\n",
    "    text = text.lower().strip()\n",
    "    # Remove multi-spaces and symbols\n",
    "    cid = re.sub(r'[^a-z0-9]+', '_', text).strip('_')\n",
    "    return cid\n",
    "\n",
    "def normalize_verb(v):\n",
    "    v = v.strip().lower()\n",
    "    # Canonical Taxonomy Verbs\n",
    "    is_a_patterns = [\n",
    "        'is_a', 'is a', 'is type of', 'belongs to', 'category of', \n",
    "        'member of', 'classified as', 'representing', 'form of'\n",
    "    ]\n",
    "    if any(p in v for p in is_a_patterns):\n",
    "        return 'is_a'\n",
    "    return v.replace(' ', '_')\n",
    "\n",
    "def load_state():\n",
    "    if os.path.exists(CHECKPOINT_FILE):\n",
    "        try:\n",
    "            with open(CHECKPOINT_FILE, \"r\") as f:\n",
    "                d = json.load(f)\n",
    "                if \"total_facts\" in d and \"cat_idx\" in d: return d\n",
    "        except: pass\n",
    "    return {\"total_facts\": 0, \"cat_idx\": 0}\n",
    "\n",
    "def save_state(count, idx):\n",
    "    with open(CHECKPOINT_FILE, \"w\") as f:\n",
    "        json.dump({\"total_facts\": count, \"cat_idx\": idx}, f)\n",
    "\n",
    "print(\"✅ Logic Normalization Engine Initialized.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "model_load" },
   "outputs": [],
   "source": [
    "# @title 🤖 Step 4: Load Symbolic Model (Edge Targeted)\n",
    "model_id = \"Qwen/Qwen2.5-1.5B-Instruct\"\n",
    "print(f\"⏳ Loading Logic Model in Optimized 4-bit ({model_id})...\")\n",
    "\n",
    "bnb_config = BitsAndBytesConfig(\n",
    "    load_in_4bit=True,\n",
    "    bnb_4bit_compute_dtype=torch.float16,\n",
    "    bnb_4bit_quant_type=\"nf4\",\n",
    "    bnb_4bit_use_double_quant=True\n",
    ")\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(model_id)\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    model_id, \n",
    "    quantization_config=bnb_config,\n",
    "    device_map=\"auto\"\n",
    ")\n",
    "model.eval()\n",
    "print(\"✅ Neuro-Symbolic Ingestion Engine Ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "process" },
   "outputs": [],
   "source": [
    "# @title 🚀 Step 5: Execute Massive Ingestion Cycle\n",
    "TARGET_NODES = 3000000000 # @param {type:\"number\"}\n",
    "CATEGORIES = [\n",
    "    \"Advanced Molecular Biology\", \"Quantum Field Mechanics\", \"Post-Classical History\", \n",
    "    \"Macroeconomic Models\", \"Cognitive Neuroscience\", \"Astrophysical Laws\", \n",
    "    \"Structural Engineering\", \"Evolutionary Psychology\", \"Digital Cryptography\",\n",
    "    \"Climate Thermodynamics\", \"Ancient Civilization Logic\", \"Global Geopolitics\"\n",
    "]\n",
    "\n",
    "state = load_state()\n",
    "count, current_idx = state['total_facts'], state['cat_idx']\n",
    "pbar = tqdm(initial=count, total=TARGET_NODES, desc=\"Ingesting Symbols\")\n",
    "\n",
    "while count < TARGET_NODES:\n",
    "    try:\n",
    "        loop_timer = time.time()\n",
    "        focus_cat = CATEGORIES[current_idx % len(CATEGORIES)]\n",
    "        \n",
    "        # Precise Data extraction prompt\n",
    "        prompt = f\"List 15 exhaustive and scientific facts about {focus_cat}. Format each as: Subject|Verb|Object|ExplainableSentence. Use unique concepts. No preamble.\"\n",
    "        messages = [\n",
    "            {\"role\": \"system\", \"content\": \"Output ONLY pipe-separated fact rows. Format: S|V|O|Sentence. Avoid list headers or conversational text.\"},\n",
    "            {\"role\": \"user\", \"content\": prompt}\n",
    "        ]\n",
    "        \n",
    "        input_text = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "        inputs = tokenizer(input_text, return_tensors=\"pt\").to(model.device)\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            out = model.generate(inputs.input_ids, max_new_tokens=1024, do_sample=True, temperature=0.75, top_p=0.9)\n",
    "        \n",
    "        response = tokenizer.decode(out[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)\n",
    "        \n",
    "        # Batch Writing Cycle\n",
    "        batch = db.batch()\n",
    "        delta = 0\n",
    "        \n",
    "        for line in response.strip().split('\\n'):\n",
    "            parts = [p.strip() for p in line.split('|')]\n",
    "            if len(parts) >= 3:\n",
    "                s, v, o = parts[0], normalize_verb(parts[1]), parts[2]\n",
    "                # Default sentence if model fails to provide one\n",
    "                sentence = parts[3] if len(parts) > 3 else f\"{s} {v.replace('_',' ')} {o}.\"\n",
    "                \n",
    "                sid, oid = clean_id(s), clean_id(o)\n",
    "                # Guard against invalid IDs or self-referential loops\n",
    "                if not sid or not oid or sid == oid: continue\n",
    "                \n",
    "                node_ref = db.collection('nodes').document(sid)\n",
    "                payload = {'name': s, 'updatedAt': firestore.SERVER_TIMESTAMP}\n",
    "                \n",
    "                if v == 'is_a':\n",
    "                    payload['groups'] = firestore.ArrayUnion([oid])\n",
    "                else:\n",
    "                    # Use ArrayUnion to prevent duplicate relations internally\n",
    "                    payload['relations'] = firestore.ArrayUnion([{\n",
    "                        'verb': v, 'targetId': oid, 'sentence': sentence, 'weight': 100\n",
    "                    }])\n",
    "                \n",
    "                batch.set(node_ref, payload, merge=True)\n",
    "                delta += 1\n",
    "        \n",
    "        if delta > 0:\n",
    "            batch.commit()\n",
    "            count += delta\n",
    "            pbar.update(delta)\n",
    "            \n",
    "            # Speed Monitoring\n",
    "            rate = delta / (time.time() - loop_timer)\n",
    "            pbar.set_postfix({\"rate\": f\"{rate:.1f} s/s\", \"cat\": focus_cat[:8]})\n",
    "            \n",
    "        current_idx += 1\n",
    "        save_state(count, current_idx)\n",
    "        \n",
    "        # Cooling and Memory Flush\n",
    "        if current_idx % 5 == 0: torch.cuda.empty_cache()\n",
    "        \n",
    "    except KeyboardInterrupt:\n",
    "        print(\"\\n🛑 Extraction Paused. State Cached.\")\n",
    "        break\n",
    "    except Exception as e:\n",
    "        print(f\"\\n⚠️ Backoff Signal: {e}. Retrying in 10s...\")\n",
    "        time.sleep(10)\n",
    "        torch.cuda.empty_cache()\n",
    "\n",
    "pbar.close()\n",
    "print(f\"✅ Knowledge Base Stabilized. Total Symbol Count: {count}\")"
   ]
  }
