    "# @title 🤖 Step 3: Load Model\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "model_id = \"Qwen/Qwen2.5-1.5B-Instruct\"\n",
    "print(\"⏳ Loading Model... (GPU)\")\n",
    "tokenizer = AutoTokenizer.from_pretrained(model_id)\n",
    "model = AutoModelForCausalLM.from_pretrained(model_id, torch_dtype=\"auto\", device_map=\"auto\")\n",
    "print(\"✅ Model loaded.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🧬 Step 4: Robust Parser Definition\n",
    "def parse_triplets(text):\n",
    "    triplets = []\n",
    "    # Split input text by lines\n",
    "    lines = text.strip().split('\\n')\n",
    "    for line in lines:\n",
    "        line = line.strip()\n",
    "        # Look for the strict '|' pipe separator\n",
    "        if '|' in line:\n",
    "            parts = line.split('|')\n",
    "            if len(parts) == 3:\n",
    "                triplets.append({'s': parts[0].strip(), 'v': parts[1].strip(), 'o': parts[2].strip()})\n",
    "            else:\n",
    "                print(f\"⚠️ Parser Warning: Line doesn't have 3 parts: '{line}'\")\n",
    "        elif len(line) > 5:\n",
    "             print(f\"⚠️ Parser Warning: No '|' in line: '{line}'\")\n",
    "    return triplets\n",
    "print(\"✅ Parser Ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🚀 Step 5: Start Ingestion Engine\n",
    "TARGET_GOAL = 500\n",
    "pbar = tqdm(total=TARGET_GOAL)\n",
    "count = 0\n",
    "\n",
    "while count < TARGET_GOAL:\n",
    "    # Force Strict Format Prompt\n",
    "    prompt = \"Generate 10 factual triplets. MUST follow format: Subject|Verb|Object. ONE triplet per line. NO EXTRA TEXT.\"\n",
    "    messages = [\n",
    "        {\"role\": \"system\", \"content\": \"You are a strict data formatter. Output only triplets in format: Subject|Verb|Object.\"},\n",
    "        {\"role\": \"user\", \"content\": prompt}\n",
    "    ]\n",
    "    text = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "    inputs = tokenizer(text, return_tensors=\"pt\").to(model.device)\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        generated_ids = model.generate(inputs.input_ids, max_new_tokens=512, do_sample=True, temperature=0.5, pad_token_id=tokenizer.eos_token_id)\n",
    "    \n",
    "    response = tokenizer.decode(generated_ids[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)\n",
    "    \n",
    "    # DEBUG: RAW OUTPUT\n",
    "    print(f\"🔍 Raw Output Snippet: {response[:300].replace('\\n', ' | ')}...\")\n",
    "    \n",
    "    triplets = parse_triplets(response)\n",
    "    print(f\"🔍 Extracted {len(triplets)} triplets.\")\n",
    "    \n",
    "    if not triplets:\n",
    "        print(f\"⚠️ Triplet Extraction Failed. Retrying in 2 seconds...\")\n",
    "        time.sleep(2)\n",
    "        continue\n",
    "    \n",
    "    # Batch Ingestion\n",
    "    batch = db.batch()\n",
    "    for t in triplets:\n",
    "        # Use a deterministic, clean document ID\n",
    "        doc_name = re.sub(r'[^a-zA-Z0-9]', '_', t['s'].lower())[:100]\n",
    "        if not doc_name: continue\n",
    "        doc_ref = db.collection('nodes').document(doc_name)\n",
    "        batch.set(doc_ref, {'relations': firestore.ArrayUnion([{'verb': t['v'], 'targetId': t['o'], 'weight': 100}])}, merge=True)\n",
    "    batch.commit()\n",
    "    \n",
    "    count += len(triplets)\n",
    "    pbar.update(len(triplets))\n",
    "pbar.close()\n",
    "print(\"✅ Ingestion Successful!\")"
   ]
  }
