   "source": [
    "# @title 🛠️ Step 1: Install Dependencies\n",
    "!pip install -q transformers accelerate bitsandbytes firebase-admin tqdm\n",
    "import os, json, re, torch, time, random\n",
    "from tqdm.auto import tqdm\n",
    "import firebase_admin\n",
    "from firebase_admin import credentials, firestore\n",
    "from google.colab import files\n",
    "print(\"✅ Environment Setup Complete.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "firebase"},
   "source": [
    "# @title 🔑 Step 2: Firebase Connection\n",
    "if not firebase_admin._apps:\n",
