   "metadata": { "id": "header" },
   "source": [
    "# 🧠 AI Logic Engine: High-Precision Knowledge Ingestion (Firestore)\n",
    "\n",
    "### 🛡️ System Audit & Integrity Pass (v3.4):\n",
    "- **Syntax Verified:** Manually checked for JSON closure and quotes.\n",
    "- **Sync-Ready ID:** Normalization logic identical to Inference Engine.\n",
    "- **Batching:** Firestore batch transaction mode for speed."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "setup" },
   "outputs": [],
   "source": [
    "# @title 🛠️ Step 1: Install & Imports\n",
    "!pip install -q firebase-admin transformers accelerate bitsandbytes torch tqdm\n",
    "\n",
    "import os, json, re, torch, time\n",
    "from tqdm.auto import tqdm\n",
    "import firebase_admin\n",
    "from firebase_admin import credentials, firestore\n",
    "from google.colab import files\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig\n",
    "\n",
    "print(\"✅ Core Libraries Ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "firebase" },
   "outputs": [],
   "source": [
    "# @title 🔑 Step 2: Firestore Connection\n",
    "DATABASE_ID = 'ai-studio-09d97652-b1c3-4b1a-b63e-31d8a38be4c2'\n",
    "\n",
    "if not firebase_admin._apps:\n",
    "    print(\"Please upload your serviceAccountKey.json file:\")\n",
    "    uploaded = files.upload()\n",
    "    if not uploaded:\n",
    "        raise ValueError(\"❌ No Service Account Key uploaded.\")\n",
    "    filename = list(uploaded.keys())[0]\n",
    "    cred = credentials.Certificate(filename)\n",
    "    firebase_admin.initialize_app(cred)\n",
    "\n",
    "db = firestore.client(database_id=DATABASE_ID)\n",
    "print(f\"✅ Successfully Connected to Memory Stack: {DATABASE_ID}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "engine_logic" },
   "outputs": [],
   "source": [
    "# @title 🧬 Step 3: Logic Normalization Engine\n",
    "STATE_FILE = \"ingestion_state_v3.json\"\n",
    "\n",
    "def clean_id(text):\n",
    "    if not text: return \"\"\n",
    "    text = text.lower().strip()\n",
    "    cid = re.sub(r'[^a-z0-9]+', '_', text).strip('_')\n",
    "    return cid\n",
    "\n",
    "def normalize_verb(v):\n",
    "    v = v.strip().lower()\n",
    "    is_a_set = ['is_a', 'is a', 'is type of', 'belongs to', 'category of', 'is classified as', 'member of']\n",
    "    if any(p == v for p in is_a_set): return 'is_a'\n",
    "    return v.replace(' ', '_')\n",
    "\n",
    "def load_state():\n",
    "    if os.path.exists(STATE_FILE):\n",
    "        try:\n",
    "            with open(STATE_FILE, \"r\") as f: return json.load(f)\n",
    "        except: pass\n",
    "    return {\"total_facts\": 0, \"cat_idx\": 0}\n",
    "\n",
    "def save_state(count, idx):\n",
    "    with open(STATE_FILE, \"w\") as f:\n",
    "        json.dump({\"total_facts\": count, \"cat_idx\": idx}, f)\n",
    "\n",
    "print(\"✅ Standardized Normalizer Configured.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "model_load" },
   "outputs": [],
   "source": [
    "# @title 🤖 Step 4: Load Symbolic Model\n",
    "model_id = \"Qwen/Qwen2.5-1.5B-Instruct\"\n",
    "print(f\"⏳ Loading Logic Model ({model_id})...\")\n",
    "bnb_config = BitsAndBytesConfig(load_in_4bit=True, bnb_4bit_compute_dtype=torch.float16, bnb_4bit_quant_type=\"nf4\")\n",
    "tokenizer = AutoTokenizer.from_pretrained(model_id)\n",
    "model = AutoModelForCausalLM.from_pretrained(model_id, quantization_config=bnb_config, device_map=\"auto\")\n",
    "model.eval()\n",
    "print(\"✅ Ingestion Engine Ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "execution_loop" },
   "outputs": [],
   "source": [
    "# @title 🚀 Step 5: Start Continuous Ingestion\n",
    "TARGET_GOAL = 3000000000 # @param {type:\"number\"}\n",
    "CATEGORIES = [\"Biology\", \"Physics\", \"History\", \"Economics\", \"Neuroscience\", \"Law\"]\n",
    "state = load_state()\n",
    "count, current_idx = state['total_facts'], state['cat_idx']\n",
    "pbar = tqdm(initial=count, total=TARGET_GOAL, desc=\"Symbols Ingested\")\n",
    "while count < TARGET_GOAL:\n",
    "    try:\n",
    "        loop_timer = time.time()\n",
    "        cat = CATEGORIES[current_idx % len(CATEGORIES)]\n",
    "        prompt = f\"Extract 15 factual symbolic triplets about {cat}. Format: S|V|O|Sentence. No intro.\"\n",
    "        messages = [{\"role\": \"system\", \"content\": \"Output ONLY pipe-separated data format: S|V|O|Sentence.\"}, {\"role\": \"user\", \"content\": prompt}]\n",
    "        input_text = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "        inputs = tokenizer(input_text, return_tensors=\"pt\").to(model.device)\n",
    "        with torch.no_grad():\n",
    "            out = model.generate(inputs.input_ids, max_new_tokens=1024, do_sample=True, temperature=0.7)\n",
    "        response = tokenizer.decode(out[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)\n",
    "        batch = db.batch()\n",
    "        added = 0\n",
    "        for line in response.strip().split('\\n'):\n",
    "            parts = [p.strip() for p in line.split('|')]\n",
    "            if len(parts) >= 3:\n",
    "                s, v, o = parts[0], normalize_verb(parts[1]), parts[2]\n",
    "                sent = parts[3] if len(parts) > 3 else f\"{s} {v} {o}.\"\n",
    "                sid, oid = clean_id(s), clean_id(o)\n",
    "                if not sid or not oid or sid == oid: continue\n",
    "                node_ref = db.collection('nodes').document(sid)\n",
    "                payload = {'name': s, 'updatedAt': firestore.SERVER_TIMESTAMP}\n",
    "                if v == 'is_a': payload['groups'] = firestore.ArrayUnion([oid])\n",
    "                else: payload['relations'] = firestore.ArrayUnion([{'verb': v, 'targetId': oid, 'sentence': sent, 'weight': 100}])\n",
    "                batch.set(node_ref, payload, merge=True)\n",
    "                added += 1\n",
    "        if added > 0:\n",
    "            batch.commit()\n",
    "            count += added\n",
    "            pbar.update(added)\n",
    "        current_idx += 1\n",
    "        save_state(count, current_idx)\n",
    "        if current_idx % 10 == 0: torch.cuda.empty_cache()\n",
    "    except KeyboardInterrupt: break\n",
    "    except Exception as e:\n",
    "        print(f\"\\n⚠️ Error: {e}\")\n",
    "        time.sleep(10)\n",
    "pbar.close()\n",
    "print(f\"✅ Cycle Closed. Total: {count}\")"
   ]
  }
 ],
