    "# @title 🔍 Step 3: Global Logic Search\n",
    "START = \"Mitochondria\" # @param {type:\"string\"}\n",
    "END = \"Cellular Energy\" # @param {type:\"string\"}\n",
    "LIMIT = 10 # @param {type:\"slider\", min:1, max:20, step:1}\n",
    "\n",
    "print(f\"🧠 Calculating Logic Path: '{START}' ➔ '{END}'...\\n\")\n",
    "proof, confidence = engine.solve_syllogism(START, END, max_depth=LIMIT)\n",
    "\n",
    "if proof:\n",
    "    print(f\"✅ Logical Chain Verified (Certainty: {confidence*100:.2f}%) \")\n",
    "    for i, step in enumerate(proof):\n",
    "        print(f\"  [{i+1}] {step}\")\n",
    "else:\n",
    "    print(f\"❌ Logic Breach: No path found in current database within {LIMIT} hops.\")\n",
    "    print(\"💡 Solution: Run the Ingestion Notebook more to gain deeper categorical knowledge.\")"
   ]
  }
