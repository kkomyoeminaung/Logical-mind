    "# 🧠 AI Logic Engine: Main Inference Console\n",
    "\n",
    "Knowledge Graph အတွင်းရှိ Concept များအကြား Logical Connection များကို ရှာဖွေပေးသည်။\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "setup" },
   "outputs": [],
   "source": [
    "# @title 🛠️ Step 1: Initialize Inference Memory\n",
    "!pip install -q firebase-admin\n",
    "\n",
    "from google.colab import files\n",
    "import firebase_admin\n",
    "from firebase_admin import credentials, firestore\n",
    "import re\n",
    "\n",
    "DATABASE_ID = 'ai-studio-09d97652-b1c3-4b1a-b63e-31d8a38be4c2'\n",
    "\n",
    "if not firebase_admin._apps:\n",
    "    print(\"Please upload your serviceAccountKey.json file:\")\n",
    "    uploaded = files.upload()\n",
    "    if not uploaded:\n",
    "        raise ValueError(\"❌ Service Account Key missing.\")\n",
    "    filename = list(uploaded.keys())[0]\n",
    "    cred = credentials.Certificate(filename)\n",
    "    firebase_admin.initialize_app(cred)\n",
    "\n",
    "db = firestore.client(database_id=DATABASE_ID)\n",
    "print(f\"✅ Memory Node Ready: {DATABASE_ID}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "inference_core" },
   "outputs": [],
   "source": [
    "# @title ⚙️ Step 2: Symbolic Logic Intelligence Core\n",
    "class KnowledgeInferenceEngine:\n",
    "    def __init__(self, db):\n",
    "        self.db = db\n",
    "        self.cache = {} # Local cache to reduce Firestore read costs\n",
    "\n",
    "    def clean_id(self, text):\n",
    "        \"\"\"CRITICAL: Must match Ingestion Normalization EXACTLY.\"\"\"\n",
    "        if not text: return \"\"\n",
    "        text = text.lower().strip()\n",
    "        return re.sub(r'[^a-z0-9]+', '_', text).strip('_')\n",
    "\n",
    "    def fetch_node(self, node_id):\n",
    "        node_key = self.clean_id(node_id)\n",
    "        if not node_key: return None\n",
    "        if node_key in self.cache: return self.cache[node_key]\n",
    "        try:\n",
    "            doc = self.db.collection('nodes').document(node_key).get()\n",
    "            if doc.exists:\n",
    "                data = doc.to_dict()\n",
    "                self.cache[node_key] = data\n",
    "                return data\n",
    "        except Exception as e:\n",
    "            print(f\"⚠️ Error reading {node_key}: {e}\")\n",
    "        return None\n",
    "\n",
    "    def solve_syllogism(self, start, target, max_depth=10):\n",
    "        \"\"\"BFS Pathfinding with High-Precision Taxonomy Support.\"\"\"\n",
    "        start_id = self.clean_id(start)\n",
    "        target_id = self.clean_id(target)\n",
    "        if start_id == target_id: return [f\"{start} is verified.\"], 1.0\n",
    "        queue = [(start_id, [], 1.0)]\n",
    "        visited = {start_id}\n",
    "        while queue:\n",
    "            curr_id, path, score = queue.pop(0)\n",
    "            if curr_id == target_id: return path, score\n",
    "            if len(path) >= max_depth: continue\n",
    "            data = self.fetch_node(curr_id)\n",
    "            if not data: continue\n",
    "            # 1. Taxonomical Inheritance (is_a)\n",
    "            for group_id in data.get('groups', []):\n",
    "                if group_id not in visited:\n",
    "                    visited.add(group_id)\n",
    "                    step = f\"{data.get('name', curr_id)} is classified under {group_id}\"\n",
    "                    queue.append((group_id, path + [step], score * 0.99))\n",
    "            # 2. Relational Connections\n",
    "            for rel in data.get('relations', []):\n",
    "                tid = rel.get('targetId')\n",
    "                if tid and tid not in visited:\n",
    "                    visited.add(tid)\n",
    "                    reason = rel.get('sentence', f\"{data.get('name', curr_id)} {rel['verb'].replace('_',' ')} {tid}\")\n",
    "                    queue.append((tid, path + [reason], score * 0.95))\n",
    "        return None, 0\n",
    "\n",
    "engine = KnowledgeInferenceEngine(db)\n",
    "print(\"✅ Inference Core Armed.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": { "id": "query" },
   "outputs": [],
   "source": [
    "# @title 🔍 Step 3: Logic Search Console\n",
    "CONCEPT_A = \"Mitochondria\" # @param {type:\"string\"}\n",
    "CONCEPT_B = \"Cellular Energy\" # @param {type:\"string\"}\n",
    "\n",
    "print(f\"🧠 Reasoning Path: '{CONCEPT_A}' ➔ '{CONCEPT_B}'...\\n\")\n",
    "proof, confidence = engine.solve_syllogism(CONCEPT_A, CONCEPT_B)\n",
    "if proof:\n",
    "    print(f\"✅ Proof Found (Certainty: {confidence*100:.2f}%) \")\n",
    "    for i, step in enumerate(proof):\n",
    "        print(f\"  [{i+1}] {step}\")\n",
    "else:\n",
    "    print(\"❌ No consistent logical chain found.\")"
   ]
  }
